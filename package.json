{
  "name": "cu-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "cd packages/server && npm run dev",
    "dev:web": "cd packages/web && npm run dev",
    "build": "cd packages/web && npm run build",
    "db:migrate": "cd packages/server && npm run db:migrate",
    "db:push": "cd packages/server && npm run db:push",
    "db:seed": "cd packages/server && npm run db:seed",
    "db:studio": "cd packages/server && npm run db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
